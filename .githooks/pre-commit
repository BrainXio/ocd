#!/usr/bin/env bash
# Git pre-commit hook: fast local quality gate.
# Delegates to ocd check for branch protection, standards verify,
# staged secret scan, staged mdformat check, and staged ruff check.
# Installed by: bash git_hooks/setup-hooks.sh

set -euo pipefail

if command -v ocd >/dev/null 2>&1; then
    exec ocd check
elif command -v uv >/dev/null 2>&1; then
    exec uv run ocd check
else
    echo "error: neither ocd nor uv found — cannot run pre-commit checks" >&2
    exit 1
fi
