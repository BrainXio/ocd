{
  "name": "brainxio-ocd-linters",
  "private": true,
  "license": "MIT",
  "description": "JSON linter/formatter for the OCD project (prettier)",
  "devDependencies": {
    "prettier": "^3.0"
  },
  "scripts": {
    "lint:json": "prettier --check '**/*.json' '!package-lock.json'",
    "format:json": "prettier --write '**/*.json' '!package-lock.json'"
  }
}
