# Managed at BrainXio/.github/defaults/
# Edit source of truth there. Local overrides minimized.
---
extends: default

rules:
  line-length:
    max: 120
    allow-non-breakable-inline-mappings: true
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  document-start: disable
