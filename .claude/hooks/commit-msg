#!/usr/bin/env bash
# Git commit-msg hook: reject AI attribution in commit messages.
# Installed by: bash .claude/scripts/setup-hooks.sh

set -euo pipefail

msg_file="$1"
msg=$(cat "$msg_file")

# Patterns that indicate AI attribution (checked against each line).
# These enforce the project policy from .claude/skills/git/SKILL.md:
#   - No Co-Authored-By lines
#   - No "Generated with/by/using" attribution
#   - No [AI] or [AI-generated] tags
ai_patterns=(
    '^Co-Authored-By:'
    '^Generated (with|by|using)'
    '^\[AI(-generated)?\]'
)

while IFS= read -r line; do
    for pattern in "${ai_patterns[@]}"; do
        if echo "$line" | grep -qiE "$pattern"; then
            echo "error: commit message contains AI attribution, which is prohibited:" >&2
            echo "  $line" >&2
            echo "" >&2
            echo "Remove the attribution line and retry. The project policy prohibits:" >&2
            echo "  - Co-Authored-By lines" >&2
            echo "  - 'Generated with/by/using' attribution" >&2
            echo "  - [AI] or [AI-generated] tags" >&2
            exit 1
        fi
    done
done <<< "$msg"

exit 0