{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ocd-session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ocd-pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ocd-session-end",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ocd-lint-work --edit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "ocd-lint-work --commit",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/id_rsa*)",
      "Read(**/docker-compose*.yml)",
      "Read(**/config/database*.yml)",
      "Read(~/Library/Keychains/**)",
      "Read(**/private/**)",
      "Edit(src/ocd/hooks/lint_work.py)",
      "Edit(src/ocd/hooks/hookslib.py)",
      "Edit(src/ocd/hooks/pre_compact.py)",
      "Edit(src/ocd/hooks/session_start.py)",
      "Edit(src/ocd/hooks/session_end.py)",
      "Edit(src/ocd/config.py)",
      "Edit(src/ocd/compile.py)",
      "Edit(src/ocd/flush.py)",
      "Edit(src/ocd/lint.py)",
      "Edit(src/ocd/query.py)",
      "Edit(src/ocd/utils.py)",
      "Edit(.gitleaks.toml)",
      "Edit(git_hooks/commit-msg)",
      "Edit(git_hooks/pre-commit)",
      "Edit(git_hooks/pre-push)",
      "Edit(git_hooks/setup-hooks.sh)",
      "Write(src/ocd/hooks/lint_work.py)",
      "Write(src/ocd/hooks/hookslib.py)",
      "Write(src/ocd/hooks/pre_compact.py)",
      "Write(src/ocd/hooks/session_start.py)",
      "Write(src/ocd/hooks/session_end.py)",
      "Write(src/ocd/config.py)",
      "Write(src/ocd/compile.py)",
      "Write(src/ocd/flush.py)",
      "Write(src/ocd/lint.py)",
      "Write(src/ocd/query.py)",
      "Write(src/ocd/utils.py)",
      "Write(.gitleaks.toml)",
      "Write(git_hooks/commit-msg)",
      "Write(git_hooks/pre-commit)",
      "Write(git_hooks/pre-push)",
      "Write(git_hooks/setup-hooks.sh)",
      "Bash(rm *:src/ocd/*)",
      "Bash(rm *:git_hooks/*)",
      "Bash(rm *:.gitleaks.toml)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": ["."],
      "denyRead": ["~/"]
    }
  }
}
