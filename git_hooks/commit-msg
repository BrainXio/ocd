#!/usr/bin/env bash
# Git commit-msg hook: reject AI attribution in commit messages.
# Delegates to ocd verify-commit for single-source-of-truth checking.
# Installed by: bash git_hooks/setup-hooks.sh

set -euo pipefail

msg_file="$1"

if command -v ocd-verify-commit >/dev/null 2>&1; then
    exec ocd-verify-commit "$msg_file"
elif command -v uv >/dev/null 2>&1; then
    exec uv run ocd verify-commit "$msg_file"
else
    echo "error: neither ocd-verify-commit nor uv found" >&2
    exit 1
fi
