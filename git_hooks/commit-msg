#!/usr/bin/env bash
# Git commit-msg hook: reject AI attribution in commit messages.
# Delegates to ocd hook verify-commit for single-source-of-truth checking.
# Installed by: bash git_hooks/setup-hooks.sh

set -euo pipefail

msg_file="$1"

if command -v uv >/dev/null 2>&1; then
    exec uv run ocd hook verify-commit "$msg_file"
else
    echo "error: uv not found, cannot run ocd hook verify-commit" >&2
    exit 1
fi
