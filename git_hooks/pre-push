#!/usr/bin/env bash
# Git pre-push hook: run diff-aware tests before pushing.
# Installed by: bash git_hooks/setup-hooks.sh

set -euo pipefail

# Delegate to the Python diff-aware test runner
if command -v ocd-pre-push >/dev/null 2>&1; then
    exec ocd-pre-push
elif command -v uv >/dev/null 2>&1; then
    exec uv run ocd-pre-push
else
    # Fallback: run full suite if ocd-pre-push is unavailable
    if ! command -v pytest >/dev/null 2>&1; then
        echo "warning: neither ocd-pre-push nor pytest found, skipping pre-push tests" >&2
        exit 0
    fi
    echo "warning: ocd-pre-push not found, running full test suite" >&2
    if ! pytest -q; then
        echo "error: tests failed — push aborted" >&2
        exit 1
    fi
fi
