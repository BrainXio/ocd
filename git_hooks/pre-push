#!/usr/bin/env bash
# Git pre-push hook: run tests before pushing.
# Installed by: bash git_hooks/setup-hooks.sh

set -euo pipefail

# Find the test runner (uv run pytest if uv is available, otherwise pytest)
if command -v uv >/dev/null 2>&1; then
    test_cmd=(uv run pytest -q)
else
    if ! command -v pytest >/dev/null 2>&1; then
        echo "warning: neither uv nor pytest found, skipping pre-push tests" >&2
        echo "  Install uv: https://docs.astral.sh/uv/" >&2
        exit 0
    fi
    test_cmd=(pytest -q)
fi

echo "running pre-push tests (${test_cmd[*]})..." >&2

if ! "${test_cmd[@]}"; then
    echo "error: tests failed — push aborted" >&2
    echo "  Fix the failures or push with --no-verify to skip this hook" >&2
    exit 1
fi

echo "pre-push tests passed" >&2
exit 0